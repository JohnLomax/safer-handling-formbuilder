APP_NAME="Safe Handler Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Local: absolute path to the shared form database
DB_DATABASE=/absolute/path/to/safe-handler-form/data/app.sqlite
APP_DATABASE_PATH=/absolute/path/to/safe-handler-form/data/app.sqlite

# Public form base URL (quotes, booking links, resume emails)
FORM_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Coolify / Docker production
# Mount a persistent volume at /var/www/html/data
# -----------------------------------------------------------------------------
# APP_URL=https://your-domain.example
# FORM_BASE_URL=https://your-domain.example
# DB_DATABASE=/var/www/html/data/app.sqlite
# APP_DATABASE_PATH=/var/www/html/data/app.sqlite
# APP_ENV=production
# APP_DEBUG=false
# LOG_CHANNEL=stderr

# -----------------------------------------------------------------------------
# Public form integrations (optional env overrides)
# Primary source of truth is Admin → Settings (stored in the settings table).
# Import into the DB with: php artisan settings:import-env
# -----------------------------------------------------------------------------
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_GROUP_ID=
MONDAY_GROUP_NAME="New Enquiries"
MONDAY_BOOKING_GROUP_NAME="Quote Accepted"
IDEAL_POSTCODES_API_KEY=
BREVO_API_KEY=
BREVO_EMAIL_ENABLED=false
BREVO_RESUME_EMAIL_ENABLED=true
BREVO_SENDER_EMAIL=training@safer-handling.co.uk
BREVO_SENDER_NAME="Safer Handling"
BREVO_CONTACT_EMAIL=training@safer-handling.co.uk
BREVO_OFFICE_EMAIL=office@safer-handling.co.uk
BREVO_LEAD_NOTIFICATION_ENABLED=true
BREVO_LOGO_URL=
BREVO_QUOTE_ACCEPT_URL=
XERO_ENABLED=false
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8000/admin/settings/xero/callback
XERO_TENANT_ID=
XERO_DEFAULT_ITEM_CODE=
XERO_SALES_ACCOUNT_CODE=200
XERO_VAT_RATE=20
XERO_BRANDING_THEME_ID=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
